# MusicGen API Configuration
# Copy to .env and customize

# API authentication (leave empty to disable auth)
API_KEY=

# Output directory for generated files
OUTPUT_DIR=/data/output

# MusicGen model selection
# Options: facebook/musicgen-small (300M, ~4GB VRAM)
#          facebook/musicgen-medium (1.5B, ~8-12GB VRAM)
#          facebook/musicgen-large (3.3B, ~16GB+ VRAM)
MUSICGEN_MODEL=facebook/musicgen-small

# Audio processing features
USE_STEM_AWARE_CROSSFADE=false
USE_QUALITY_LOOP=true
MAX_REGEN_ATTEMPTS=3

# ─── ACE-Step 1.5 configuration ───
# DiT model variant (turbo recommended for budget GPUs)
ACESTEP_CONFIG_PATH=acestep-v15-turbo

# Language model size: acestep-5Hz-lm-0.6B, acestep-5Hz-lm-1.7B, acestep-5Hz-lm-4B
ACESTEP_LM_MODEL_PATH=acestep-5Hz-lm-0.6B

# LM backend: "pt" (PyTorch, universal) or "vllm" (faster, needs Ampere+ GPU)
# Use "pt" for Pascal GPUs (GTX 1070/1080, T1000) - no Flash Attention support
ACESTEP_LM_BACKEND=pt

# LLM initialization: auto, true, false
# Set to "false" for DiT-only mode (faster, less VRAM, no thinking/planning)
ACESTEP_INIT_LLM=auto

# GPU device ID for ACE-Step (0-indexed)
# In dual-GPU setups, set to 1 to use the second GPU
ACESTEP_CUDA_DEVICE_ID=0

# ─── CUDA configuration ───
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=all
